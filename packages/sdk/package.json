{
	"name": "@trustless-work/sdk-solana",
	"version": "0.1.0",
	"description": "TypeScript SDK for Trustless Work on Solana",
	"license": "MIT",
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		},
		"./react": {
			"types": "./dist/react.d.ts",
			"import": "./dist/react.mjs",
			"require": "./dist/react.js"
		}
	},
	"files": ["dist"],
	"scripts": {
		"build": "tsup",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"axios": "^1.9.0"
	},
	"peerDependencies": {
		"react": ">=18.0.0"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/react": "^19.0.0",
		"react": "^19.0.0",
		"tsup": "^8.4.0",
		"typescript": "^5.8.2"
	}
}
